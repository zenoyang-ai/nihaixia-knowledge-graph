/* pages/index/index.wxss — 宣纸气质，少卡片外框 */
.index-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--surface-page);
  padding: 0 40rpx 80rpx;
  box-sizing: border-box;
}

.index-hero {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 80rpx 0 40rpx;
}

.index-hero-badge {
  display: inline-block;
  padding: 0 0 4rpx;
  border-bottom: 1rpx solid var(--accent-border);
  margin-bottom: 28rpx;
}

.index-hero-badge text {
  font-size: 22rpx;
  color: var(--accent);
  letter-spacing: 0.08em;
}

.index-hero-title {
  margin-bottom: 16rpx;
}

.index-hero-title text {
  font-size: 52rpx;
  font-weight: 600;
  color: var(--on-surface-strong);
  letter-spacing: 0.02em;
  line-height: 1.3;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.index-hero-subtitle {
  margin-bottom: 20rpx;
}

.index-hero-subtitle text {
  font-size: 28rpx;
  color: var(--on-surface-muted);
  line-height: 1.6;
}

.index-hero-warn {
  padding: 20rpx 0;
  border-top: 1rpx solid var(--divider-warm);
  border-bottom: 1rpx solid var(--divider-warm);
}

.index-hero-warn text {
  font-size: 22rpx;
  color: var(--accent);
  line-height: 1.5;
}

.index-actions {
  margin-top: 40rpx;
}

.index-primary-btn {
  width: 100%;
  padding: 28rpx 0;
  background: var(--accent);
  text-align: center;
  box-sizing: border-box;
}

.index-primary-btn text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--on-accent);
  letter-spacing: 0.06em;
}

.index-primary-btn-hover {
  background: var(--accent-hover);
}

.index-section-title {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin: 56rpx 0 16rpx;
}

.index-section-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--on-surface-strong);
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.index-section-title-action {
  font-size: 24rpx;
  color: var(--accent);
  padding: 16rpx 12rpx;
  min-height: 64rpx;
  display: inline-flex;
  align-items: center;
}

.index-session-row {
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--divider-warm);
}

.index-session-row-hover {
  background: var(--surface-hover);
  margin: 0 -16rpx;
  padding-left: 16rpx;
  padding-right: 16rpx;
}

.index-session-card-title text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--on-surface-strong);
  line-height: 1.45;
}

.index-session-card-meta {
  margin-top: 8rpx;
}

.index-session-card-meta text {
  font-size: 22rpx;
  color: var(--on-surface-faint);
}

.index-empty {
  margin-top: 80rpx;
  text-align: center;
}

.index-empty-text text {
  font-size: 28rpx;
  color: var(--on-surface-muted);
}

.index-empty-hint {
  margin-top: 12rpx;
}

.index-empty-hint text {
  font-size: 24rpx;
  color: var(--on-surface-faint);
}

.index-privacy-link {
  margin-top: 48rpx;
  text-align: center;
}

.index-privacy-link text {
  font-size: 24rpx;
  color: var(--on-surface-faint);
  text-decoration: underline;
}
