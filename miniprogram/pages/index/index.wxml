<!--pages/index/index.wxml-->
<view class="index-container">

  <!-- 顶部标题区 -->
  <view class="index-hero">
    <view class="index-hero-badge">
      <text>学习资料库</text>
    </view>
    <view class="index-hero-title">
      <text>经典中医学习问答</text>
    </view>
    <view class="index-hero-subtitle">
      <text>从经典、概念与学习路径开始提问</text>
    </view>
    <view class="index-hero-warn">
      <text>仅供学习研究 · 不提供诊断、处方或剂量建议</text>
    </view>
  </view>

  <!-- 主操作 -->
  <view class="index-actions">
    <view class="index-primary-btn" bindtap="onStartChat">
      <text>开始学习对话</text>
    </view>
  </view>

  <!-- 最近对话 -->
  <view class="index-recent" wx:if="{{recentSessions.length > 0}}">
    <view class="index-section-title">
      <text class="index-section-title-text">最近对话</text>
      <text class="index-section-title-action" bindtap="onViewAllHistory">查看全部 ({{totalSessions}})</text>
    </view>
    <view class="index-session-list">
      <view
        class="index-session-card"
        wx:for="{{recentSessions}}"
        wx:key="sessionId"
        bindtap="onContinueSession"
        data-session-id="{{item.sessionId}}"
      >
        <view class="index-session-card-title">
          <text>{{item.title || '未命名对话'}}</text>
        </view>
        <view class="index-session-card-meta">
          <text>{{item.messageCount}} 条消息 · {{item.updatedAtText}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="index-empty" wx:else>
    <view class="index-empty-text">
      <text>还没有学习对话记录</text>
    </view>
    <view class="index-empty-hint">
      <text>点击上方按钮开始第一次对话</text>
    </view>
  </view>

</view>
