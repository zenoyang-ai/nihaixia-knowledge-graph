/* pages/history/history.wxss — 分隔线列表，对齐 Demo，扩大点击热区 */

.history-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--surface-page);
}

.history-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 28rpx;
  background: var(--surface-glass);
  border-bottom: 1rpx solid var(--divider-warm);
  flex-shrink: 0;
}

.history-toolbar-text {
  font-size: 24rpx;
  color: var(--on-surface-muted);
  letter-spacing: 0.02em;
}

.history-clear-btn {
  min-height: 64rpx;
  padding: 12rpx 22rpx;
  background: transparent;
  border: 1rpx solid var(--border-color);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-clear-btn text {
  font-size: 24rpx;
  color: var(--accent);
  letter-spacing: 0.04em;
}

.history-clear-btn:active {
  background: var(--accent-soft);
  border-color: var(--accent);
}

.history-list {
  flex: 1;
  padding: 0 28rpx;
}

/* 分隔线列表，去掉白底描边卡片 */
.history-card {
  display: flex;
  align-items: stretch;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid var(--divider-warm);
  margin-bottom: 0;
  overflow: visible;
}

.history-card-main {
  flex: 1;
  padding: 28rpx 12rpx 28rpx 0;
  min-width: 0;
}

.history-card-main:active .history-card-title text {
  color: var(--accent);
}

.history-card-title {
  margin-bottom: 8rpx;
}

.history-card-title text {
  font-size: 30rpx;
  color: var(--on-surface-strong);
  font-weight: 500;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.history-card-preview {
  margin-bottom: 10rpx;
}

.history-card-preview text {
  font-size: 24rpx;
  color: var(--on-surface-muted);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.history-card-meta text {
  font-size: 22rpx;
  color: var(--on-surface-faint);
  letter-spacing: 0.02em;
}

.history-card-delete {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  padding: 0 20rpx;
  background: transparent;
  border-left: none;
  align-self: stretch;
}

.history-card-delete text {
  font-size: 26rpx;
  color: var(--accent);
  letter-spacing: 0.02em;
  padding: 16rpx 8rpx;
}

.history-card-delete:active {
  background: var(--accent-soft);
}

.history-bottom-spacer {
  height: calc(48rpx + env(safe-area-inset-bottom));
}

.history-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.history-empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--surface-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.history-empty-icon text {
  font-size: 36rpx;
  color: var(--on-surface-faint);
  font-weight: 600;
}

.history-empty-text {
  margin-bottom: 12rpx;
}

.history-empty-text text {
  font-size: 30rpx;
  color: var(--on-surface-muted);
}

.history-empty-hint {
  margin-bottom: 40rpx;
}

.history-empty-hint text {
  font-size: 24rpx;
  color: var(--on-surface-faint);
  letter-spacing: 0.04em;
}

.history-empty-btn {
  min-height: 80rpx;
  padding: 18rpx 56rpx;
  background: var(--accent);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-empty-btn text {
  color: var(--on-accent);
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 0.06em;
}

.history-empty-btn:active {
  background: var(--accent-hover);
}
