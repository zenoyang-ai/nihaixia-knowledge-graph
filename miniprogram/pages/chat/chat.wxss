/* pages/chat/chat.wxss
 *
 * 设计语言：案头学习索引
 *   底色 #F7F7F4 / 墨色 #263238 / 辅助 #6B767A
 *   资料库状态 #55776C / 主操作 #B94736 / 分隔线 #DCE2DD
 */

.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F7F7F4;
}

/* ===========================
 * 顶部导航栏（返回 + 标题 + 历史）
 * =========================== */
.chat-navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 28rpx;
  background: rgba(247, 247, 244, 0.96);
  border-bottom: 1rpx solid #DCE2DD;
  flex-shrink: 0;
}

.chat-navbar-back {
  padding: 8rpx 20rpx 8rpx 0;
  min-width: 120rpx;
}

.chat-navbar-back text {
  font-size: 28rpx;
  color: #55776C;
  letter-spacing: 0.02em;
}

.chat-navbar-back:active text {
  color: #3E5A52;
}

.chat-navbar-title {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat-navbar-title text {
  font-size: 28rpx;
  font-weight: 600;
  color: #263238;
  letter-spacing: 0.04em;
}

.chat-navbar-history {
  padding: 8rpx 0 8rpx 20rpx;
  min-width: 120rpx;
  display: flex;
  justify-content: flex-end;
}

.chat-navbar-history text {
  font-size: 26rpx;
  color: #55776C;
  letter-spacing: 0.02em;
}

.chat-navbar-history:active text {
  color: #3E5A52;
}

/* ===========================
 * 对话状态栏（对话中显示）
 * =========================== */
.chat-statusbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 28rpx;
  background: rgba(247, 247, 244, 0.96);
  border-bottom: 1rpx solid #DCE2DD;
  flex-shrink: 0;
}

.chat-statusbar-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chat-status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #55776C;
  box-shadow: 0 0 0 4rpx rgba(85, 119, 108, 0.16);
}

.chat-statusbar-text {
  font-size: 26rpx;
  color: #263238;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.chat-clear-btn {
  padding: 6rpx 22rpx;
  background: transparent;
  border: 1rpx solid #DCE2DD;
  border-radius: 10rpx;
}

.chat-clear-btn text {
  font-size: 24rpx;
  color: #6B767A;
  letter-spacing: 0.04em;
}

.chat-clear-btn:active {
  background: #EEF1ED;
  border-color: #55776C;
}

/* ===========================
 * 消息列表
 * =========================== */
.chat-messages {
  flex: 1;
  padding: 16rpx 24rpx 0;
  overflow-y: auto;
}

/* ===========================
 * 欢迎区（紧凑首屏）
 * =========================== */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding: 48rpx 4rpx 24rpx;
}

.welcome-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.welcome-status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #55776C;
  box-shadow: 0 0 0 4rpx rgba(85, 119, 108, 0.16);
}

.welcome-status text {
  font-size: 22rpx;
  color: #6B767A;
  letter-spacing: 0.06em;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #263238;
  letter-spacing: 0.02em;
  line-height: 1.3;
  margin-bottom: 8rpx;
}

.welcome-subtitle {
  font-size: 26rpx;
  color: #6B767A;
  margin-bottom: 18rpx;
}

.welcome-tag {
  display: inline-block;
  align-self: flex-start;
  padding: 6rpx 16rpx;
  background: rgba(85, 119, 108, 0.08);
  border: 1rpx solid rgba(85, 119, 108, 0.18);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #55776C;
  letter-spacing: 0.02em;
  margin-bottom: 36rpx;
}

.welcome-section-title {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.welcome-section-title text:first-child {
  font-size: 24rpx;
  font-weight: 600;
  color: #263238;
  letter-spacing: 0.06em;
}

.welcome-hint {
  font-size: 20rpx;
  color: #9AA1A4;
  letter-spacing: 0.04em;
}

/* ===========================
 * 横滑问笺（一屏 1~1.5 张）
 * =========================== */
.question-strip {
  width: 100%;
  white-space: nowrap;
  margin: 0 -24rpx;
  padding: 0 24rpx;
}

.question-strip-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0 12rpx;
}

.question-card {
  display: inline-flex;
  align-items: center;
  width: 490rpx;
  height: 104rpx;
  padding: 0 20rpx 0 14rpx;
  background: #FFFFFF;
  border: 1rpx solid #DCE2DD;
  border-radius: 10rpx;
  flex-shrink: 0;
  transition: all 0.18s;
  box-sizing: border-box;
}

.question-card:active {
  background: #F4F7F4;
  border-color: #55776C;
  transform: scale(0.985);
}

.question-card-num {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(85, 119, 108, 0.08);
  border-radius: 6rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.question-card-num text {
  font-size: 24rpx;
  font-weight: 600;
  color: #55776C;
  letter-spacing: 0.02em;
}

.question-card-text {
  flex: 1;
  overflow: hidden;
  min-width: 0;
}

.question-card-text text {
  font-size: 26rpx;
  color: #263238;
  line-height: 1.4;
  white-space: normal;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.question-card-arrow {
  width: 28rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
}

.question-card-arrow text {
  font-size: 36rpx;
  color: #9AA1A4;
  line-height: 1;
}

/* ===========================
 * 消息行
 * =========================== */
.msg-row {
  display: flex;
  margin-bottom: 22rpx;
  align-items: flex-start;
}

.msg-row-user {
  justify-content: flex-end;
}

.msg-row-ai {
  justify-content: flex-start;
}

/* AI 头像：低调绿色圆角方形 */
.msg-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 10rpx;
  background: #55776C;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.msg-avatar-text {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.04em;
}

/* ===========================
 * 消息气泡
 * =========================== */
.msg-bubble {
  max-width: 580rpx;
  padding: 22rpx 26rpx;
  border-radius: 14rpx;
  font-size: 29rpx;
  line-height: 1.75;
  word-break: break-word;
  letter-spacing: 0.01em;
}

.msg-bubble-user {
  background: #B94736;
  color: #FFFFFF;
  border-bottom-right-radius: 4rpx;
  user-select: text;
  -webkit-user-select: text;
}

.msg-bubble-ai {
  background: #FFFFFF;
  color: #263238;
  border: 1rpx solid #DCE2DD;
  border-bottom-left-radius: 4rpx;
  /* 允许长按复制 */
  user-select: text;
  -webkit-user-select: text;
}

.msg-bubble-ai rich-text {
  font-size: 29rpx;
  line-height: 1.75;
  letter-spacing: 0.01em;
  /* rich-text 内部段落间距 */
  display: block;
}

/* 来源数量提示 */
.msg-sources {
  margin-top: 10rpx;
  padding-top: 8rpx;
  border-top: 1rpx dashed #DCE2DD;
}

.msg-sources text {
  font-size: 22rpx;
  color: #55776C;
  letter-spacing: 0.04em;
}

.msg-sources:active text {
  color: #3E5A52;
}

/* provider 标签（无来源时才显示） */
.msg-provider {
  margin-top: 8rpx;
  padding-top: 6rpx;
  border-top: 1rpx solid #EEF1ED;
}

.msg-provider text {
  font-size: 20rpx;
  color: #9AA1A4;
  letter-spacing: 0.04em;
}

/* 重新发送按钮 */
.msg-retry {
  margin-top: 10rpx;
  padding: 8rpx 20rpx;
  background: transparent;
  border: 1rpx solid #B94736;
  border-radius: 10rpx;
  display: inline-block;
}

.msg-retry text {
  font-size: 22rpx;
  color: #B94736;
  letter-spacing: 0.04em;
}

.msg-retry:active {
  background: rgba(185, 71, 54, 0.06);
}

/* ===========================
 * 加载中动画
 * =========================== */
.typing-dots {
  display: flex;
  gap: 8rpx;
  align-items: center;
  padding: 4rpx 0;
}

.typing-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #9AA1A4;
  animation: typingBlink 1.4s infinite both;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typingBlink {
  0%, 80%, 100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  40% {
    opacity: 1;
    transform: scale(1);
  }
}

/* 底部占位 */
.chat-bottom-spacer {
  height: 24rpx;
}

/* ===========================
 * 输入区（紧凑）
 * =========================== */
.chat-input-area {
  padding: 10rpx 24rpx;
  padding-bottom: calc(10rpx + env(safe-area-inset-bottom));
  background: rgba(247, 247, 244, 0.96);
  border-top: 1rpx solid #DCE2DD;
  flex-shrink: 0;
}

.chat-input-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chat-input {
  flex: 1;
  height: 76rpx;
  min-height: 76rpx;
  max-height: 76rpx;
  padding: 12rpx 22rpx;
  background: #FFFFFF;
  border: 1rpx solid #DCE2DD;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #263238;
  line-height: 1.5;
  box-sizing: border-box;
  overflow-y: auto;
}

.chat-input-placeholder {
  color: #9AA1A4;
  font-size: 26rpx;
}

.chat-send-btn {
  width: 106rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #EEF1ED;
  color: #9AA1A4;
  border: 1rpx solid #DCE2DD;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 0.04em;
  flex-shrink: 0;
  transition: all 0.18s;
  box-sizing: border-box;
}

.chat-send-btn-active {
  background: #B94736;
  color: #FFFFFF;
  border-color: #B94736;
}

.chat-send-btn-active:active {
  background: #9C3A2C;
  transform: scale(0.96);
}

.chat-input-hint {
  text-align: center;
  margin-top: 6rpx;
}

.chat-input-hint text {
  font-size: 18rpx;
  color: #9AA1A4;
  letter-spacing: 0.04em;
}

/* ===========================
 * 段落复制弹层
 * =========================== */
.copy-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.copy-panel {
  width: 100%;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 20rpx 20rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  animation: copyPanelSlideUp 0.2s ease-out;
}

@keyframes copyPanelSlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.copy-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #DCE2DD;
  flex-shrink: 0;
}

.copy-panel-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #263238;
  letter-spacing: 0.04em;
}

.copy-panel-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.copy-panel-close text {
  font-size: 44rpx;
  color: #9AA1A4;
  line-height: 1;
}

.copy-panel-close:active text {
  color: #6B767A;
}

.copy-panel-body {
  flex: 1;
  padding: 16rpx 28rpx;
  max-height: 60vh;
}

.copy-paragraph-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #EEF1ED;
}

.copy-paragraph-item:last-child {
  border-bottom: none;
}

.copy-paragraph-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 8rpx;
  background: rgba(85, 119, 108, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 18rpx;
}

.copy-paragraph-num text {
  font-size: 24rpx;
  font-weight: 600;
  color: #55776C;
}

.copy-paragraph-content {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.copy-paragraph-content text {
  font-size: 27rpx;
  color: #263238;
  line-height: 1.65;
  word-break: break-word;
}

.copy-paragraph-action {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  background: rgba(85, 119, 108, 0.08);
  border: 1rpx solid rgba(85, 119, 108, 0.18);
  border-radius: 8rpx;
  align-self: center;
}

.copy-paragraph-action text {
  font-size: 22rpx;
  color: #55776C;
  letter-spacing: 0.04em;
}

.copy-paragraph-item:active .copy-paragraph-action {
  background: #55776C;
}

.copy-paragraph-item:active .copy-paragraph-action text {
  color: #FFFFFF;
}

.copy-panel-footer {
  padding: 18rpx 28rpx;
  background: #F7F7F4;
  border-top: 1rpx solid #DCE2DD;
  text-align: center;
  flex-shrink: 0;
}

.copy-panel-footer text {
  font-size: 22rpx;
  color: #9AA1A4;
  letter-spacing: 0.04em;
}
