<!--pages/chat/chat.wxml-->
<view class="chat-container">

  <!-- 对话状态栏（状态 + 历史入口 + 新对话） -->
  <view class="chat-statusbar">
    <view class="chat-statusbar-left">
      <view class="chat-status-dot"></view>
      <text class="chat-statusbar-text">学习对话</text>
    </view>
    <view class="chat-statusbar-right">
      <view class="chat-history-btn" bindtap="onViewHistory">
        <text>历史</text>
      </view>
      <view class="chat-clear-btn" wx:if="{{messages.length > 0}}" bindtap="onClearChat">
        <text>新对话</text>
      </view>
    </view>
  </view>

  <!-- 消息列表 / 欢迎屏 -->
  <scroll-view
    class="chat-messages"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
    enhanced
    show-scrollbar="{{false}}"
  >
    <!-- 欢迎区 -->
    <view class="welcome-section" wx:if="{{messages.length === 0}}">
      <view class="welcome-status">
        <view class="welcome-status-dot"></view>
        <text>学习资料库</text>
      </view>
      <view class="welcome-title">倪师智慧学习问答</view>
      <view class="welcome-subtitle">从经典、概念与学习路径开始提问</view>
      <view class="welcome-tag">仅供学习研究 · 不提供诊断、处方或剂量建议</view>

      <view class="welcome-section-title">
        <text>从这里开始</text>
        <text class="welcome-hint">向左滑动查看更多</text>
      </view>

      <!-- 横滑问笺 -->
      <scroll-view
        class="question-strip"
        scroll-x
        show-scrollbar="{{false}}"
        enhanced
      >
        <view class="question-strip-inner">
          <view
            class="question-card"
            wx:for="{{suggestedQuestions}}"
            wx:key="index"
            bindtap="onSuggestedTap"
            data-question="{{item}}"
          >
            <view class="question-card-num">
              <text>{{index + 1}}</text>
            </view>
            <view class="question-card-text">
              <text>{{item}}</text>
            </view>
            <view class="question-card-arrow">
              <text>›</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 消息列表 -->
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}">
      <!-- 用户消息 -->
      <view class="msg-row msg-row-user" wx:if="{{item.role === 'user'}}">
        <view
          class="msg-bubble msg-bubble-user"
          bindlongpress="onLongPressMessage"
          data-content="{{item.content}}"
          data-id="{{item.id}}"
        >
          <text user-select="{{true}}">{{item.content}}</text>
        </view>
      </view>

      <!-- AI 消息 -->
      <view class="msg-row msg-row-ai" wx:else>
        <view class="msg-avatar">
          <text class="msg-avatar-text">学</text>
        </view>
        <view
          class="msg-bubble msg-bubble-ai"
          bindlongpress="onLongPressMessage"
          data-content="{{item.content}}"
          data-id="{{item.id}}"
        >
          <block wx:if="{{item.content}}">
            <rich-text nodes="{{item.html}}" wx:if="{{item.html}}" user-select="{{true}}"></rich-text>
            <text wx:else user-select="{{true}}">{{item.content}}</text>
          </block>
          <view wx:else class="typing-wrap">
            <view class="typing-dots">
              <view class="typing-dot"></view>
              <view class="typing-dot"></view>
              <view class="typing-dot"></view>
            </view>
            <text class="typing-stage">{{loadingStage}}</text>
          </view>
          <!-- 来源数量提示：仅当 hasSources 为 true 时显示 -->
          <view
            class="msg-sources"
            wx:if="{{item.hasSources}}"
            bindtap="onShowSources"
            data-sources="{{item.sources}}"
          >
            <text>学习资料库 · 引用 {{item.sources.length}} 条资料</text>
          </view>
          <!-- provider 标签：无来源时才显示 -->
          <view class="msg-provider" wx:if="{{!item.hasSources}}">
            <text>{{item.provider === 'cloudbase-hybrid' ? '学习资料库' : item.provider === 'cloudbase-llm' ? '学习资料库' : item.provider === 'system' ? '系统' : item.provider === 'error' ? '错误' : '学习资料库'}}</text>
          </view>
          <view class="msg-retry" wx:if="{{item.provider === 'error'}}" bindtap="onRetry" data-question="{{item.retryQuestion}}">
            <text>重新发送</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="chat-bottom-spacer" id="chat-bottom"></view>
  </scroll-view>

  <!-- 输入区 -->
  <view class="chat-input-area">
    <view class="chat-input-wrap">
      <textarea
        class="chat-input"
        value="{{inputValue}}"
        bindinput="onInput"
        bindconfirm="onSend"
        placeholder="输入关于倪师智慧的学习问题…"
        placeholder-class="chat-input-placeholder"
        confirm-type="send"
        maxlength="1000"
        show-confirm-bar="{{false}}"
        adjust-position="{{true}}"
        cursor-spacing="20"
        disabled="{{loading}}"
        auto-height
      />
      <view
        class="chat-send-btn {{(canSend && !loading) ? 'chat-send-btn-active' : ''}}"
        bindtap="onSend"
      >
        <text>{{loading ? '处理中' : '发送'}}</text>
      </view>
    </view>
    <view class="chat-input-hint">
      <text>学习资料库 · 不提供诊断、处方或剂量建议</text>
    </view>
  </view>

  <!-- 段落复制弹层 -->
  <view class="copy-panel-mask" wx:if="{{copyPanelVisible}}" bindtap="onCloseCopyPanel">
    <view class="copy-panel" catchtap="onCopyPanelTap">
      <view class="copy-panel-header">
        <text class="copy-panel-title">{{copyTitle}}</text>
        <view class="copy-panel-close" bindtap="onCloseCopyPanel">
          <text>×</text>
        </view>
      </view>
      <scroll-view class="copy-panel-body" scroll-y enhanced show-scrollbar="{{false}}">
        <view
          class="copy-paragraph-item"
          wx:for="{{copyParagraphs}}"
          wx:key="index"
          bindtap="onCopyParagraph"
          data-index="{{index}}"
        >
          <view class="copy-paragraph-num">
            <text>{{index + 1}}</text>
          </view>
          <view class="copy-paragraph-content">
            <text user-select="{{true}}">{{item}}</text>
          </view>
          <view class="copy-paragraph-action">
            <text>复制</text>
          </view>
        </view>
      </scroll-view>
      <view class="copy-panel-footer">
        <text>共 {{copyParagraphs.length}} 段 · 点击任意段落即复制</text>
      </view>
    </view>
  </view>

</view>
